{
  "name": "contrastcheck",
  "version": "1.1.0",
  "description": "Check color contrast accessibility on websites",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "contrastcheck": "bin/contrastcheck.js"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --packages external --sourcemap=none",
    "dev": "bun src/index.ts",
    "check": "bun bin/contrastcheck.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "vitest run && vitest run --config vitest.e2e.config.ts",
    "prepublishOnly": "bun run build",
    "bump": "nyron bump",
    "push-tag": "nyron push-tag",
    "release:local": "nyron release --use-existing-tag",
    "release:dry": "nyron release --dry-run"
  },
  "keywords": [
    "accessibility",
    "a11y",
    "contrast",
    "wcag",
    "color"
  ],
  "author": "m7md1alaa",
  "license": "ISC",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m7md1alaa/contrast-check.git"
  },
  "bugs": {
    "url": "https://github.com/m7md1alaa/contrast-check/issues"
  },
  "homepage": "https://github.com/m7md1alaa/contrast-check#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "culori": "^4.0.2",
    "handlebars": "^4.7.9",
    "inquirer": "^13.4.2",
    "ora": "^9.4.0",
    "playwright": "^1.59.1",
    "zod": "^4.4.0"
  },
  "devDependencies": {
    "@nyron/cli": "^0.8.1",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}